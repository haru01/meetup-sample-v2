{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "./.claude/hooks/dep-install-guard.sh",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "./.claude/hooks/secret-leak-detector.sh",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "bash": "./.claude/hooks/prettier-format.sh",
        "timeoutSec": 15
      },
      {
        "type": "command",
        "bash": "./.claude/hooks/lint-guard.sh",
        "timeoutSec": 30
      }
    ]
  }
}
